  {
    title: "Machine Learning Developer",
    org: "Embraer",
    period: "Sep 2024 – Feb 2025",
    description: "Failure prediction models for commercial aircraft (E2 jets) using Random Forest, KNN, XGBoost, PyTorch and TensorFlow. Led backend and infrastructure development for an aircraft data platform — database modeling, API design, and implementation.",
  },
  {
    title: "MSc in Computer Science",
    org: "UNIFESP — Federal University of São Paulo",
    period: "2024 – present",
    description: "Research in Artificial Neural Networks, Machine Learning, and Agentic Systems.",
  },
  {
    title: "Full-Stack Web Developer",
    org: "TORQI S.A.",
    period: "Jan 2023 – May 2023",
    description: "Full-stack development with focus on backend and system architecture. Contributed to business and architecture decision-making.",
  },
  {
    title: "Junior Full-Stack Developer",
    org: "Buser",
    period: "Nov 2020 – Dec 2022",
    description: "Built microservices, APIs, and full projects for the customer service platform. Focused on scalability and observability. Mentored interns and delivered internal tech talks.",
  },
  {
    title: "BSc in Science and Technology",
    org: "UNIFESP — Federal University of São Paulo",
    period: "2020 – 2024",
    description: "Undergraduate degree with focus on algorithms, data structures, and software engineering.",
  },
];
---

<section id="experience" class="bg-surface py-20 px-6 flex flex-col items-center justify-center">
  <div class="w-full max-w-2xl">
    <span class="font-mono text-accent text-sm tracking-widest uppercase mb-12 block text-center animate-item">Experience & Education</span>

    <div class="relative border-l-2 border-border pl-8 space-y-16">
      {items.map((item) => (
        <div class="exp-item relative animate-item">
          <div class="absolute -left-[41px] w-4 h-4 rounded-full bg-surface border-2 border-accent"></div>
          <span class="font-mono text-accent text-xs tracking-widest uppercase">{item.period}</span>
          <h3 class="text-text font-semibold text-lg mt-1">{item.title}</h3>
          <p class="text-muted text-sm mt-1">{item.org}</p>
          <p class="text-muted text-sm mt-3 leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .animate-item {
    opacity: 0;
    transform: translateX(20px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .animate-item.visible {
    opacity: 1;
    transform: translateX(0);
  }
</style>

<script>
  const items = document.querySelectorAll('#experience .animate-item');
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.1 }
  );
  items.forEach(el => observer.observe(el));
</script>
