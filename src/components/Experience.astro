---
const items = [
  {
    title: "MSc in Computer Science",
    org: "UNIFESP — Federal University of São Paulo",
    period: "2024 – present",
    description: "Research in Artificial Neural Networks, Machine Learning and Agentic Systems.",
  },
  {
    title: "BSc in Computer Science",
    org: "UNIFESP — Federal University of São Paulo",
    period: "2020 – 2024",
    description: "Undergraduate studies with focus on algorithms, data structures and software engineering.",
  },
];
---

<section id="experience" class="bg-surface py-24 px-6">
  <div class="max-w-2xl mx-auto">
    <span class="font-mono text-accent text-sm tracking-widest uppercase mb-10 block">Experience & Education</span>

    <div class="relative border-l-2 border-border pl-8 space-y-12">
      {items.map((item, i) => (
        <div
          class={`exp-item relative opacity-0 translate-x-[20px]`}
          data-index={i}
        >
          <div class="absolute -left-[41px] w-4 h-4 rounded-full bg-surface border-2 border-accent"></div>

          <span class="font-mono text-accent text-xs tracking-widest uppercase">{item.period}</span>
          <h3 class="text-text font-semibold text-lg mt-1">{item.title}</h3>
          <p class="text-muted text-sm mt-1">{item.org}</p>
          <p class="text-muted text-sm mt-3 leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.to(".exp-item", {
    opacity: 1,
    x: 0,
    duration: 0.7,
    stagger: 0.2,
    ease: "power2.out",
    scrollTrigger: {
      trigger: "#experience",
      start: "top 75%",
    },
  });
</script>
