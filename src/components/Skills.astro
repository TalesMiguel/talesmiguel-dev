---
const categories = [
  {
    label: "Languages",
    skills: ["Python", "C", "JavaScript", "TypeScript", "SQL"],
  },
  {
    label: "ML / AI",
    skills: ["PyTorch", "TensorFlow", "Scikit-learn", "XGBoost", "Data Science"],
  },
  {
    label: "Backend & Web",
    skills: ["Django", "FastAPI", "Vue.js", "React", "PostgreSQL", "Redis", "MySQL"],
  },
  {
    label: "Infra & Tools",
    skills: ["Docker", "Git", "Nginx", "Linux", "Microservices", "TDD", "Scrum"],
  },
];
---

<section id="skills" class="py-36 px-6">
  <div class="max-w-3xl mx-auto text-center">
    <span class="font-mono text-accent text-sm tracking-widest uppercase mb-12 block">Skills</span>

    <div class="space-y-10">
      {categories.map((cat) => (
        <div>
          <h3 class="font-mono text-muted text-xs tracking-widest uppercase mb-5">{cat.label}</h3>
          <div class="flex flex-wrap gap-3 justify-center">
            {cat.skills.map((skill) => (
              <span class="skill-pill font-mono text-sm px-4 py-2 border border-border text-muted">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.from(".skill-pill", {
    opacity: 0,
    y: 10,
    duration: 0.5,
    stagger: 0.05,
    ease: "power2.out",
    scrollTrigger: {
      trigger: "#skills",
      start: "top 75%",
    },
  });
</script>
