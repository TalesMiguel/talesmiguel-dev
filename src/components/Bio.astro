---
const bio = "I'm a Master's student in Computer Science at UNIFESP (São José dos Campos), researching Artificial Neural Networks, Machine Learning, and Agentic Systems. I also bring hands-on industry experience as an ML Developer in the aviation sector and as a full-stack engineer in road transport and other startups.";
const accent = "When not training models, you'll likely find me behind a drum kit or playing guitar.";
---

<section id="bio" class="bg-surface px-6 flex flex-col items-center justify-center">
  <div class="w-full max-w-2xl text-center">
    <span class="font-mono text-accent text-sm tracking-widest uppercase mb-8 block">About</span>
    <p id="bio-text" class="text-text text-lg leading-relaxed mb-8">
      {bio}
    </p>
    <p id="bio-accent" class="font-mono text-accent text-sm border-l-2 border-accent pl-4 text-left">
      {accent}
    </p>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.from(["#bio-text", "#bio-accent"], {
    opacity: 0,
    x: -20,
    duration: 0.8,
    stagger: 0.2,
    ease: "power2.out",
    scrollTrigger: {
      trigger: "#bio",
      start: "top 75%",
    },
  });
</script>
