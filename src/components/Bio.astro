---
const bio = "I'm a Master's student at the Federal University of São Paulo (UNIFESP), where my research focuses on Artificial Neural Networks, Machine Learning, and Agentic Systems. I'm interested in building intelligent systems that interact meaningfully with the real world.";
const accent = "When not training models, you'll likely find me behind a drum kit or playing guitar.";
---

<section id="bio" class="bg-surface py-24 px-6">
  <div class="max-w-2xl mx-auto">
    <span class="font-mono text-accent text-sm tracking-widest uppercase mb-6 block">About</span>
    <p id="bio-text" class="text-text text-lg leading-relaxed mb-6 opacity-0 translate-x-[-20px]">
      {bio}
    </p>
    <p id="bio-accent" class="font-mono text-accent text-sm border-l-2 border-accent pl-4 opacity-0 translate-x-[-20px]">
      {accent}
    </p>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.to(["#bio-text", "#bio-accent"], {
    opacity: 1,
    x: 0,
    duration: 0.8,
    stagger: 0.2,
    ease: "power2.out",
    scrollTrigger: {
      trigger: "#bio",
      start: "top 75%",
    },
  });
</script>
