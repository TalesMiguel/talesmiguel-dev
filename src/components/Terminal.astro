---
// No server-side props
---

<div class="w-full max-w-2xl px-4">
  <!-- Terminal window -->
  <div class="terminal-window overflow-hidden rounded-lg" style="border: 1px solid rgba(34,211,238,0.25); box-shadow: 0 0 60px rgba(34,211,238,0.1);">
    <!-- Title bar -->
    <div class="flex items-center gap-2 px-4 py-3 border-b" style="background:#111111; border-color: rgba(34,211,238,0.15);">
      <span class="w-3 h-3 rounded-full" style="background:#ff5f57;"></span>
      <span class="w-3 h-3 rounded-full" style="background:#febc2e;"></span>
      <span class="w-3 h-3 rounded-full" style="background:#28c840;"></span>
      <span class="font-mono text-muted text-xs ml-2">tales@dev ~</span>
    </div>

    <!-- Terminal body -->
    <div class="p-6 font-mono text-sm leading-relaxed" style="background:#0d0d0d;">
      <div class="text-muted">
        <span class="text-accent">~</span> via <span class="text-accent">ssh</span>
      </div>
      <div class="mt-4 flex items-center">
        <span class="text-accent">$</span>
        <span id="terminal-cmd" class="text-text ml-2"></span>
        <span id="terminal-cursor" class="text-accent ml-px">█</span>
      </div>

      <!-- Output shown after typing -->
      <div id="terminal-output" style="display:none;" class="mt-6">
        <div class="text-muted text-xs mb-4">Connecting to ssh.talesmiguel.dev...</div>
        <pre class="text-accent text-xs leading-tight overflow-x-auto"> _____     _             __  __ _                  _
|_   _|_ _| | ___  ___  |  \/  (_) __ _ _   _  ___| |
  | |/ _` | |/ _ \/ __| | |\/| | |/ _` | | | |/ _ \ |
  | | (_| | |  __/\__ \ | |  | | | (_| | |_| |  __/ |
  |_|\__,_|_|\___||___/ |_|  |_|_|\__, |\__,_|\___|_|
                                   |___/</pre>
        <div class="mt-4 text-muted text-xs">
          <p>Welcome! Navigate with <span class="text-accent">arrow keys</span> or <span class="text-accent">j/k</span></p>
          <p class="mt-1">
            <span class="text-accent">[about]</span>
            <span class="text-muted ml-2">[skills]</span>
            <span class="text-muted ml-2">[experience]</span>
            <span class="text-muted ml-2">[education]</span>
            <span class="text-muted ml-2">[contact]</span>
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <p id="terminal-cta" class="text-center text-muted text-sm font-mono mt-6" style="opacity:0; transition: opacity 0.6s ease;">
    Try it yourself:
    <code class="text-accent px-2 py-1 select-all" style="background:#111111; border-radius:4px;">ssh ssh.talesmiguel.dev</code>
  </p>
</div>

<script>
  let started = false;

  function startAnimation() {
    if (started) return;
    started = true;

    const cmd    = "ssh ssh.talesmiguel.dev";
    const el     = document.getElementById("terminal-cmd")!;
    const cursor = document.getElementById("terminal-cursor")!;
    const output = document.getElementById("terminal-output")!;
    const cta    = document.getElementById("terminal-cta")!;
    let i = 0;

    function typeCmd() {
      if (i < cmd.length) {
        el.textContent += cmd[i++];
        setTimeout(typeCmd, 55 + Math.random() * 35);
      } else {
        setTimeout(() => {
          cursor.style.display = "none";
          output.style.display = "block";
          cta.style.opacity = "1";
        }, 400);
      }
    }

    setTimeout(typeCmd, 600);
  }

  // Start when the view-terminal overlay becomes visible
  const viewTerminal = document.getElementById('view-terminal');
  if (viewTerminal) {
    const mo = new MutationObserver(() => {
      if (!viewTerminal.classList.contains('hidden')) {
        startAnimation();
      }
    });
    mo.observe(viewTerminal, { attributes: true, attributeFilter: ['class'] });
  }
</script>
