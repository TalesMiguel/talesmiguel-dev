---
// No server-side props
---

<div class="w-full px-8" style="max-width: 860px;">
  <!-- Terminal window -->
  <div class="terminal-window overflow-hidden rounded-lg" style="border: 1px solid rgba(34,211,238,0.25); box-shadow: 0 0 80px rgba(34,211,238,0.12);">
    <!-- Title bar -->
    <div class="flex items-center gap-2 px-6 py-4 border-b" style="background:#111111; border-color: rgba(34,211,238,0.15);">
      <span class="w-3 h-3 rounded-full" style="background:#ff5f57;"></span>
      <span class="w-3 h-3 rounded-full" style="background:#febc2e;"></span>
      <span class="w-3 h-3 rounded-full" style="background:#28c840;"></span>
      <span class="font-mono text-muted text-sm ml-3">tales@dev ~</span>
    </div>

    <!-- Terminal body -->
    <div class="font-mono leading-relaxed" style="background:#0d0d0d; padding: 2.5rem 3rem;">
      <div class="text-muted text-base">
        <span class="text-accent">~</span> via <span class="text-accent">ssh</span>
      </div>
      <div class="flex items-center" style="margin-top: 1.5rem;">
        <span class="text-accent text-base">$</span>
        <span id="terminal-cmd" class="text-text text-base ml-2"></span>
        <span id="terminal-cursor" class="text-accent text-base ml-px">█</span>
      </div>

      <!-- Output shown after typing -->
      <div id="terminal-output" style="display:none; margin-top: 2.5rem;">
        <div class="text-muted" style="font-size: 0.8rem; margin-bottom: 1.5rem;">Connecting to ssh.talesmiguel.dev...</div>
        <pre class="text-accent overflow-x-auto" style="font-size: 0.8rem; line-height: 1.4;"> _____     _             __  __ _                  _
|_   _|_ _| | ___  ___  |  \/  (_) __ _ _   _  ___| |
  | |/ _` | |/ _ \/ __| | |\/| | |/ _` | | | |/ _ \ |
  | | (_| | |  __/\__ \ | |  | | | (_| | |_| |  __/ |
  |_|\__,_|_|\___||___/ |_|  |_|_|\__, |\__,_|\___|_|
                                   |___/</pre>
        <div style="margin-top: 2rem;">
          <p class="text-muted" style="font-size: 0.85rem;">
            Welcome! Navigate with <span class="text-accent">arrow keys</span> or <span class="text-accent">j/k</span>
          </p>
          <div class="flex flex-wrap gap-3" style="margin-top: 1rem;">
            <span class="text-accent" style="font-size: 0.85rem;">[about]</span>
            <span class="text-muted" style="font-size: 0.85rem;">[skills]</span>
            <span class="text-muted" style="font-size: 0.85rem;">[experience]</span>
            <span class="text-muted" style="font-size: 0.85rem;">[education]</span>
            <span class="text-muted" style="font-size: 0.85rem;">[contact]</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <p id="terminal-cta" class="text-center text-muted font-mono" style="opacity:0; transition: opacity 0.6s ease; margin-top: 2rem; font-size: 0.9rem;">
    Try it yourself:
    <code class="text-accent px-3 py-1 select-all" style="background:#111111; border-radius:4px; margin-left: 0.5rem;">ssh ssh.talesmiguel.dev</code>
  </p>
</div>

<script>
  let started = false;

  function startAnimation() {
    if (started) return;
    started = true;

    const cmd    = "ssh ssh.talesmiguel.dev";
    const el     = document.getElementById("terminal-cmd")!;
    const cursor = document.getElementById("terminal-cursor")!;
    const output = document.getElementById("terminal-output")!;
    const cta    = document.getElementById("terminal-cta")!;
    let i = 0;

    function typeCmd() {
      if (i < cmd.length) {
        el.textContent += cmd[i++];
        setTimeout(typeCmd, 55 + Math.random() * 35);
      } else {
        setTimeout(() => {
          cursor.style.display = "none";
          output.style.display = "block";
          cta.style.opacity = "1";
        }, 400);
      }
    }

    setTimeout(typeCmd, 600);
  }

  // Start when the view-terminal overlay becomes visible
  const viewTerminal = document.getElementById('view-terminal');
  if (viewTerminal) {
    const mo = new MutationObserver(() => {
      if (!viewTerminal.classList.contains('hidden')) {
        startAnimation();
      }
    });
    mo.observe(viewTerminal, { attributes: true, attributeFilter: ['class'] });
  }
</script>
